<% if @user.creator_setting&.images&.attached? %>
  <div class="main-view" style="background-images: url('<%= url_for(@user.creator_setting.images[0]) %>');"></div>
<% else %>
  <div class="main-view"></div>
<% end %>

<div class="user-body-container">
  <div class="user-top">
    <div class="avatar-container flex-shrink-0"><%= user_avatar(@user, 180, 400, class:"user-avatar") %></div>
    <div class="user-body-area column flex-1 min-w-0">
      <h1 class="user-name text-2xl font-bold mb-4"><%= @user.name %></h1>
      <div class="flex space-x-4 mb-7">
        <%= link_to @user.twitter, target: "_blank" do %>
          <i class="fa-brands fa-square-x-twitter text-2xl"></i>
        <% end if @user.twitter? %>

        <%= link_to @user.pixiv, target: "_blank" do %>
          <i class="fa-brands fa-pixiv text-[#0096FA] text-2xl"></i>
        <% end if @user.pixiv? %>

        <%= link_to @user.instagram, target: "_blank" do %>
          <i class="fa-brands fa-instagram text-[#C13584] text-2xl"></i>
        <% end if @user.instagram? %>
      </div>
      <p class="break-words">
        <%= @user.creator_setting&.body %>
      </p>
    </div>
  </div>
</div>

<div class="user-main-container">
  <div data-controller="user" class="">
    <nav class="flex justify-center mb-4">
      <%= link_to "ホーム", user_path(@user),
      class: "user-content-menu",
      data: { 
      user_target: "link",
      action: "click->user#border", 
      turbo_frame: "user_content" } 
      %>

      <%= link_to "ポートフォリオ", user_portfolio_path(@user),
      class: "user-content-menu",
      data: { 
      user_target: "link",
      action: "click->user#border", 
      turbo_frame: "user_content" } 
      %>
      <%= link_to "開催中のリクエスト", user_received_request_path(@user),
      class: "user-content-menu",
        data: { 
      user_target: "link",
      action: "click->user#border", 
      turbo_frame: "user_content" } 
      %>
      <%= link_to "作成したリクエスト", user_sent_request_path(@user),
      class: "user-content-menu",
        data: { 
      user_target: "link",
      action: "click->user#border", 
      turbo_frame: "user_content" } 
      %>
      <%= link_to "支援したリクエスト", user_supported_request_path(@user),
      class: "user-content-menu",
        data: { 
      user_target: "link",
      action: "click->user#border", 
      turbo_frame: "user_content" } 
      %>
    </nav>
    <%= turbo_frame_tag "user_content" do %>
      <div class="main-menu">
        <div class="request-box"> 
          <ul style="padding: 10px;">
            <li class="flex mb-4" style="border-bottom: 1px solid rgb(138, 138, 138); padding: 4px; line-height: 1.5;">
              <p style="font-weight: 550; margin-right: auto;">作品数</p>
              <% (@user.received_requests.size)? %>
            </li>
            <li class="flex mb-4" style="border-bottom: 1px solid rgb(138, 138, 138); padding: 4px; line-height: 1.5;">
              <p style="font-weight: 550; margin-right: auto;">完成期限</p>
              <% if (@creator_setting.present?) %>
                <p style="">
                  <span style="margin-right: 4px;"><%= @creator_setting.delivery_deadline %></span>
                  <span class="text-xs">日</span>
                </p>
              <% else %>
                <p style="">未設定</p>
              <% end %>
            </li>
            <li class="flex mb-4" style="border-bottom: 1px solid rgb(138, 138, 138); padding: 4px; line-height: 1.5;"><p style="font-weight: 550; margin-right: auto;">完成期限厳守率</p><p style=""><span style="margin-right: 4px;">作品数</span><span class="text-xs">日</span></p></li>
            <li class="flex mb-4" style="border-bottom: 1px solid rgb(138, 138, 138); padding: 4px; line-height: 1.5;"><p style="font-weight: 550; margin-right: auto;">最低支援金額</p><p style=""><span style="margin-right: 4px;">10000000</span><span class="text-xs">円</span></p></li>
            <li class="flex mb-4" style="border-bottom: 1px solid rgb(138, 138, 138); padding: 4px; line-height: 1.5;"><p style="font-weight: 550; margin-right: auto;">最低支援者数</p><p style=""><span style="margin-right: 4px;"><%= (@creator_setting.present?)? @creator_setting.minimum_supporters : "未設定"%></span><span class="text-xs">人</span></p></li>
          </ul>

          <% if @creator_setting&.published? %>
            <%= link_to "リクエストを送る", new_request_path(creator_setting: @creator_setting), data: { turbo_frame: "_top" }, class: "button", style: "--bg-color: red;" %>
          <% else %>
            <div class="button" style= "--bg-color: gray;">受け付けていません</div>
          <% end %>
        </div>
        <div class="deliverables">
          <% if @creator_setting.present? %>
          <%= render "shared/deliverables", creator_setting: @creator_setting %>
          <% else %>
            <p style="text-align: center; color: #666; padding: 40px 0;">作品は現在投稿されていません</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>


