
  <% if requests.present?%>  
    <ul class="request-card-box">
      <% requests.each do |request| %>
        <li class="request-card">
          <%= link_to request do %>
            <div class="image-container">
              <%= image_tag default_image(request.request_images[0]), class: "card-image" %>
            </div>
            <div class="request-card-footer">
              <div style="padding: 12px">
                <div class="request-card-title"><%=request.title%></div>
              </div>
              <div class="meter-area">
                <% percentage = (request.current_amount.to_f / request.target_amount * 100) %>
                <p class="success-rate-sp"><%= percentage.round %>%</p>
                <div class="meter">
                  <div class="meter-bar" style="width: <%= percentage.clamp(0,100).round(1) %>%;"></div> 
                  <p class="success-rate">
                    <%= percentage.round %><span class="suffix">%</span>
                  </p>
                </div>
              </div>
              <div class="request-card-footer-contents-container">
                <div class="request-card-footer-contents">
                  <p class="text-xs">支援総額</p>
                  <p><span class="font-bold text-xs inline-block mr-1"><%=request.current_amount%></span><span>円<span></p>
                </div>
                <div class="request-card-footer-contents">
                  <p class="text-xs">支援者</p>
                  <p><span class="font-bold text-xs inline-block mr-1"><%=request.support_histories.size%></span><span>人<span></p>
                </div>

              
                <% diff = request.deadline_at - Time.current.floor %>
                <% days = (diff / 1.day).to_i %>
                <% hours = (diff / 1.hour % 24).to_i %>
                <% minutes = (diff / 1.minute % 60).to_i %>

                <div class="request-card-footer-contents">
                  <p class="text-xs">残り日数</p>
                  <% if request.deadline_at > Time.current.floor %>
                    <% if days > 0 %>
                      <p><span class="font-bold text-xs inline-block mr-1"><%= days %></span><span>日<span></p>
                    <% elsif hours > 0 %>
                      <p><span class="font-bold text-xs inline-block mr-1"><%= hours %></span><span>時間<span></p>
                    <% elsif minutes > 0 %>
                      <p><span class="font-bold text-xs inline-block mr-1"><%= minutes %></span><span>分<span></p>
                    <% end %>
                  <% else %>
                    <p><span class="font-bold text-xs inline-block mr-1">終了</span></p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p style="text-align: center; color: #666; padding: 40px 0;">現在投稿されていません</p>
  <% end %>