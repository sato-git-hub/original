  <% if requests.present?%>  
    <ul class="request-card-box">
      <% requests.each do |request| %>
        <li class="request-card">
          <%= link_to request do %>
            <div class="image-container">
              <%= image_tag default_image(request.request_images[0]), class: "card-image" %>
            </div>
            <div class="request-card-top flex flex-col p-4 gap-4">
              <div class="request-card-title"><%=request.title%></div>
              <div class="aa rounded flex flex-col p-4 gap-4">
                  <div class="meter-area">
                    <% amount_percentage = (request.current_amount.to_f / request.target_amount * 100) %>
                    <p class="success-rate-sp"><%= amount_percentage.round %>%</p>
                    <div class="flex gap-2">
                      <span class="text-xs">支援金</span>
                      <div class="meter" style="--h: 14px; flex: 1;">
                        <div class="meter-bar" style="width: <%= amount_percentage.clamp(0,100).round(1) %>%;"></div>
                        <p class="success-rate">
                          <%= amount_percentage.round %><span class="suffix">%</span>
                        </p>
                      </div>
                    </div>
                    
                  </div>
                  <div class="meter-area">
                    <p class="success-rate-sp"><%= amount_percentage.round %>%</p>
                    <div class="flex gap-2">
                      <span class="text-xs">支援者</span>
                      <div class="meter" style="--h: 14px; flex: 1;">
                        <% supporter_percentage = (request.supporters_count.to_f / request.creator.creator_setting.minimum_supporters * 100) %>
                        <div class="meter-bar" style="width: <%= supporter_percentage.clamp(0,100).round(1) %>%;"></div> 
                        <p class="success-rate">
                          <%= supporter_percentage.round %><span class="suffix">%</span>
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
            <div class="request-card-footer flex flex-col p-4 gap-4">
                            <div class="flex items-center gap-4">
                <div style="flex: 3;">
                              <div class="text-xs" style="margin-bottom:4px;">依頼先</div>
                  <div class="flex items-center">
      
                    <p style="flex-shrink: 0;"><%= user_avatar(request.creator, 30) %></p>
                    <p class="request-card-creator-name font-bold text-sm "><%= request.creator.name %></p>
                  </div>
                </div>
                <% diff = request.deadline_at - Time.current.floor %>
                <% days = (diff / 1.day).to_i %>
                <% hours = (diff / 1.hour % 24).to_i %>
                <% minutes = (diff / 1.minute % 60).to_i %>

                <div style="flex: 1;">

                  <% if request.deadline_at > Time.current.floor %>
                    <% if days > 0 %>
                      <p class="text-xs"><span class="font-bold inline-block mr-1"><%= days %></span><span>日<span></p>
                    <% elsif hours > 0 %>
                      <p><span class="font-bold text-xs inline-block mr-1"><%= hours %></span><span>時間<span></p>
                    <% elsif minutes > 0 %>
                      <p><span class="font-bold text-xs inline-block mr-1"><%= minutes %></span><span>分<span></p>
                    <% end %>
                  <% else %>
                    <p><span class="font-bold text-xs inline-block mr-1">終了</span></p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p style="text-align: center; color: #666; padding: 40px 0;">現在投稿されていません</p>
  <% end %>
