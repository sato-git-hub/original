<% if requests.present? %>
  <% 
    count = requests.size 

    max_width = case
                when count == 1 then "400px"
                when count == 2 then "800px"
                when count == 3 then "1000px"
                else "1200px"
                end
  %>

  <div style="column-width: 250px; column-gap: 16px; width: 100%; max-width: <%= max_width %>; margin: 0 auto;">
    <% requests.each do |request| %>
      <% if request.deliverable.attached? %> 
        <div style="break-inside: avoid; margin-bottom: 16px;">
          <%= image_tag default_image(request.deliverable), style: "width: 100%; height: auto; display: block; border-radius: 8px;" %>
        </div>
      <% else %>
        <div style="break-inside: avoid; margin-bottom: 16px;">
          <%= image_tag "no_image.jpeg", style: "width: 100%; height: auto; display: block; border-radius: 8px;" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p style="text-align: center; color: #666; padding: 40px 0;">現在投稿されていません</p>
<% end %>

