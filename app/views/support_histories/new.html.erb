<div class="page-container" style="--mw: 800px; --pt: 100px;">
  <%= form_with model: [@request, @support_history], data: { turbo: false } do |f| %>

    <h2 class="text-lg font-bold">こちらのクリエーターに支援します</h2>
    <div class="my-8 p-6 border border-gray-200 rounded-xl bg-gray-50 text-center flex justify-center">
       <div class="creator-card" style="width:300px;">
          <%= link_to @request.creator, class: "creator-card-wrapper" do %>
            <div class="creator-image-area relative">
              <div class="creator-image-container">
                <%= image_tag @request.creator.creator_setting.images[0], class: "card-image", style: "--ratio: 2 / 1;" %>
                <% if @request.creator.creator_setting.published? %>
                  <div class="card-tag-area">
                    <div class="card-tag-container">
                      <div class="tag">募集中</div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="creator-body-area">
              <div class="creator-avatar-container">
                <%= user_avatar(@request.creator, 60, class: "creator-avatar-image") %>
              </div>
              <div class="creator-about-container">
                <div class="creator-name font-bold text-lg"><%= @request.creator.name %></div>
                <div class="creator-received-requests"><span class="mr-4">開催中のリクエスト:</span><%= @request.creator.received_requests.size %>件</div>
              </div>
            </div>
          <% end %>
        </div>
    </div>

    <h2 class="text-lg font-bold">決済内容</h2>
    <div class="my-8 p-6 border border-gray-200 rounded-xl bg-gray-50 text-center">
      <div class="payment-about flex items-center p-4">
        <div class="payment-amount flex flex-col flex-1 justify-center items-center" style="80px;">

          <h2 class="text-gray-700 text-xl font-bold mb-4">決済金額</h2>
          <div class="flex items-center">
            <i class="fa-solid fa-yen-sign"></i>
            <%= f.number_field :amount,
                  required: true,
                  min: 300,
                  class: "border rounded text-center" %>
          </div>
        </div>

        <div class="flex flex-col flex-1 justify-center items-center">
          <h2 class="text-gray-700 text-xl font-bold mb-4"></h2>

          <section class="max-w-fit mx-auto font-bold text-base pb-4">
            <% if current_user.payjp_customer_id.present? %>
              <label class="block mb-2 cursor-pointer">
                <%# 存在したらcheck初期状態からつけた状態で %>
                <input type="radio" name="payment_type" value="registered" checked 
                        onclick="selectRegistered()">
                登録済みのカード（**** **** **** <%= current_user.last4 || "----" %>）で決済する
              </label>
            <% end %>
          
            <label class="block cursor-pointer">
              <%# onclick で JS を直接実行してフォームを表示する %>
              <input type="radio" name="payment_type" value="new" 
                      <%= current_user.payjp_customer_id.present? ? "" : "checked" %>
                      onclick="selectNew()">
              新しいカード情報を入力する
            </label>
          </section>

          <script>
            // Pay.jp でカード入力が完了し、トークンが生成された時に呼ばれる
            window.onTokenCreated = function(token) {
              console.log("成功")
              const submitBtn = document.getElementById('rails-submit-button');
              submitBtn.disabled = false; // ボタンを押せるようにする
              submitBtn.style.removeProperty('--bg-color', 'gray'); // グレーアウト解除（クラス名は調整してください）
            }
            function selectRegistered(){
              document.getElementById('new-card-form').style.display='none'
              const submitBtn = document.getElementById('rails-submit-button');
              submitBtn.disabled = false;
              submitBtn.style.removeProperty('--bg-color', 'gray');
              submitBtn.value = "支援を確定する"
            }

            function selectNew(){
              document.getElementById('new-card-form').style.display=''
              const submitBtn = document.getElementById('rails-submit-button');
              submitBtn.disabled = true;

              submitBtn.style.setProperty('--bg-color', 'gray');
              submitBtn.value = "カード情報を入力してください"
            }
          </script>

          <%# 新規カード用フォーム（PAY.JPチェックアウト） %>
          <div id="new-card-form" style="display:;">
            <script
              src="https://checkout.pay.jp/"
              class="payjp-button"
              data-key="<%= ENV['PAYJP_PUBLIC_KEY'] %>"
              data-text="カード情報を入力する"
              data-submit-text="支援を確定する"
              data-partial="true"
              data-on-created="onTokenCreated"
            ></script>
          </div>
        </div>
      </div>
    </div>

    <%= f.submit "支援を確定する", 
      id: "rails-submit-button", 
      class: "fixed button w-full disabled:cursor-not-allowed", 
      style: "#{current_user.payjp_customer_id.blank? ? '--bg-color: gray;' : ''} position: fixed; bottom: 0; left: 0;",
      disabled: current_user.payjp_customer_id.blank? %>
  <% end %>
</div>

