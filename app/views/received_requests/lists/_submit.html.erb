<div class="request-title flex flex-col gap-2 mb-6">
  <p class="mb-2"><%= l request.updated_at, format: :simple  %></p>
  <div class="flex items-center gap-4">
    <div class="text-sm" style="flex: 0 0 auto;">リクエスト名:</div>
    <div class="title"><%= request.title %></div>
  </div>
  <div class="flex items-center gap-6">
    <div class="text-sm" style="flex: 0 0 auto;">依頼金額:</div>
    <div class="title"><%= request.target_amount %></div>
  </div>
</div>
